APP_ENV=local
LOG_LEVEL=INFO

# MODEL_PROVIDER: openai | anthropic | openai_compatible
MODEL_PROVIDER=openai
MODEL_NAME=gpt-4o-mini
MODEL_TEMPERATURE=0.2
# MODEL_BASE_URL is required only for MODEL_PROVIDER=openai_compatible
MODEL_BASE_URL=

REQUEST_TIMEOUT_S=60

# Research tools
TAVILY_API_KEY=

# LLM providers
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Harness controls
MAX_AGENT_RETRIES=3
MAX_IMAGE_RETRIES=2
MAX_AUDIT_ROUNDS=2
TOOL_RATE_LIMIT_PER_MINUTE=20

DATA_DIR=./data
CHECKPOINT_SQLITE_PATH=./data/checkpoints.sqlite3
